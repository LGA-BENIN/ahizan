{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:server": "nodemon --watch \"src/**/*.ts\" --exec \"ts-node --transpileOnly\" src/index.ts",
    "dev:worker": "ts-node --transpileOnly ./src/index-worker.ts",
    "dev:dashboard": "vite --clearScreen false",
    "dev": "concurrently --kill-others npm:dev:*",
    "run:fast": "concurrently --kill-others \"npm run dev:server\" \"npm run dev:worker\"",
    "clean-ports": "npx kill-port 3000",
    "build": "tsc",
    "build:dashboard": "vite build",
    "start:server": "node ./dist/index.js",
    "start:worker": "node ./dist/index-worker.js",
    "start": "concurrently npm:start:*",
    "migration:generate": "node node_modules/@vendure/cli/dist/cli.js migrate --generate",
    "migration:run": "node node_modules/@vendure/cli/dist/cli.js migrate --run",
    "migration:revert": "node node_modules/@vendure/cli/dist/cli.js migrate --revert"
  },
  "dependencies": {
    "@apollo/client": "^3.14.0",
    "@craftjs/core": "^0.2.12",
    "@tanstack/react-query": "^5.0.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-link": "^3.26.0",
    "@tiptap/extension-text-align": "^3.26.0",
    "@tiptap/extension-youtube": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@vendure/asset-server-plugin": "^3.6.4",
    "@vendure/core": "^3.6.4",
    "@vendure/dashboard": "^3.6.4",
    "@vendure/email-plugin": "^3.6.4",
    "@vendure/graphiql-plugin": "^3.6.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "12.6.2",
    "dotenv": "^17.2.3",
    "graphql-tag": "^2.12.6",
    "pg": "^8.13.1",
    "prismjs": "^1.30.0",
    "react-router-dom": "^6.30.3",
    "react-simple-code-editor": "^0.14.1",
    "tiptap-extension-resize-image": "^1.4.3",
    "typeorm": "^0.3.28",
    "xlsx": "^0.18.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@swc/core": "1.13.5",
    "@types/nodemailer": "^6.4.16",
    "@vendure/cli": "3.5.2",
    "concurrently": "9.2.1",
    "nodemon": "^3.1.11",
    "typescript": "5.8.2"
  },
  "overrides": {
    "@swc/core": "1.13.5",
    "@tanstack/react-router": "^1.105.0",
    "@tanstack/router-plugin": "^1.105.0",
    "@tanstack/router-devtools": "^1.105.0"
  }
}
